{
  "name": "vuepress-theme-yur",
  "version": "4.0.0",
  "description": "VuePress Theme - Yur",
  "keywords": [
    "vuepress-theme-yur",
    "vuepress-theme",
    "vuepress",
    "theme",
    "yur"
  ],
  "homepage": "https://github.com/cnguu/vuepress-theme-yur/",
  "bugs": {
    "url": "https://github.com/cnguu/vuepress-theme-yur/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cnguu/vuepress-theme-yur.git"
  },
  "license": "MIT",
  "author": "cnguu <www@cnguu.cn>",
  "main": "lib/node/index.js",
  "types": "lib/node/index.d.ts",
  "files": [
    "lib"
  ],
  "scripts": {
    "tsc": "tsc -b tsconfig.build.json",
    "clean": "rimraf lib *.tsbuildinfo docs/.vuepress/.temp docs/.vuepress/.cache docs/.vuepress/dist",
    "copy": "cpx \"src/**/*.{d.ts,vue,less}\" lib",
    "dev": "yarn copy & yarn tsc & vuepress dev docs --clean-cache",
    "build": "vuepress build docs --clean-cache",
    "serve": "anywhere -h localhost -d docs/.vuepress/dist",
    "lint": "eslint --ext .js,.ts,.vue .",
    "prepare": "husky install"
  },
  "lint-staged": {
    "*.{js,ts,vue}": "eslint --fix",
    "*.{json,yml,css,less}": "prettier --write",
    "package.json": "sort-package-json"
  },
  "prettier": "prettier-config-vuepress",
  "dependencies": {
    "@vuepress/cli": "2.0.0-beta.14",
    "@vuepress/client": "2.0.0-beta.12",
    "@vuepress/core": "2.0.0-beta.14",
    "@vuepress/plugin-git": "^2.0.0-beta.14",
    "@vuepress/plugin-theme-data": "2.0.0-beta.14",
    "@vuepress/shared": "2.0.0-beta.7",
    "@vuepress/utils": "2.0.0-beta.11",
    "less": "^4.1.1",
    "less-loader": "^8.1.1",
    "vue": "^3.0.11",
    "vue-router": "^4.0.8"
  },
  "devDependencies": {
    "anywhere": "^1.5.0",
    "cpx2": "^3.0.0",
    "eslint": "^7.26.0",
    "eslint-config-vuepress": "^3.2.1",
    "eslint-config-vuepress-typescript": "^2.2.1",
    "husky": "^6.0.0",
    "lint-staged": "^10.5.4",
    "prettier": "^2.3.0",
    "prettier-config-vuepress": "^1.2.0",
    "rimraf": "^3.0.2",
    "sort-package-json": "^1.49.0",
    "stylelint": "^13.8.0",
    "stylelint-config-prettier": "^8.0.2",
    "stylelint-config-standard": "^20.0.0",
    "stylelint-order": "^4.1.0",
    "typescript": "^4.2.4"
  }
}
